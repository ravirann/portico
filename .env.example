# Copy to .env (gitignored) and fill in. The CLI loads .env automatically.
# Secret refs in an instance file map to env vars as:  a/b  →  PORTICO_SECRET_A_B

# UR Medicine MyChart credentials (used by the urmc instance)
PORTICO_SECRET_URMC_USERNAME=
PORTICO_SECRET_URMC_PASSWORD=
# Authenticator-app 2FA only — the base32 "setup key" (not the QR code).
# Leave blank for SMS 2FA (you'll tap the code once, headed).
PORTICO_SECRET_URMC_TOTP_SEED=

# Optional: enable AI self-heal / AI extraction (author/heal tier, off the hot path)
# PORTICO_HEAL_PROVIDER=anthropic
# PORTICO_HEAL_API_KEY=
